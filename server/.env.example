# ============================================================
# MMMS Server — Environment Variables
# ============================================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ---- Server ------------------------------------------------
NODE_ENV=development
PORT=5000

# ---- PostgreSQL (Neon) ------------------------------------
# Get this from your Neon dashboard → Connection Details
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# ---- JWT ---------------------------------------------------
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=replace_with_a_strong_random_secret_minimum_64_characters
JWT_EXPIRES_IN=8h

# ---- CORS --------------------------------------------------
# Frontend URL (no trailing slash)
# Development:  http://localhost:5173
# Production:   https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# ---- Uploads -----------------------------------------------
# Base URL for serving uploaded files
# Development:  http://localhost:5000
# Production:   https://your-api.onrender.com
UPLOADS_BASE_URL=http://localhost:5000

# ---- Rate Limiting (contact form) -------------------------
# Maximum submissions per window per IP
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=10
