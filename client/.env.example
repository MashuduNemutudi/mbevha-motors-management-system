# ============================================================
# MMMS Client — Environment Variables
# ============================================================
# Copy this file to .env.local and set the correct values.
#
# IN DEVELOPMENT:
#   Leave VITE_API_URL empty. The Vite dev proxy handles /api
#   automatically (configured in vite.config.js).
#
# IN PRODUCTION (Vercel):
#   Set VITE_API_URL to your Render backend URL.
#   Go to Vercel dashboard → Project → Settings → Environment Variables
#   Add: VITE_API_URL = https://your-api-name.onrender.com
#
# WITHOUT THIS SET IN PRODUCTION, the app will be blank because
# all API calls go to /api on the Vercel domain, which has no backend.
# ============================================================

VITE_API_URL=https://your-api-name.onrender.com
